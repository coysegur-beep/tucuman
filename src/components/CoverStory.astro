---
import type { ResolvedArticle } from "~/lib/types";
import { formatRelative } from "~/lib/format";
import { SAMPLE_TODAY } from "~/lib/now";

interface Props {
  article: ResolvedArticle;
}

const { article } = Astro.props;
const { imagenPrincipal, categoria, autor, titulo, copete, fechaPublicacion } =
  article;
---

<section class="bg-bone">
  <div class="mx-auto max-w-[1400px] px-6 pt-8">
    <a href={article.url} class="group block">
      <div class="relative h-[380px] w-full overflow-hidden sm:h-[360px]">
        <img
          src={imagenPrincipal.url}
          alt={imagenPrincipal.alt}
          class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
          loading="eager"
          fetchpriority="high"
          width="1600"
          height="900"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/40 to-transparent"
          aria-hidden="true"
        >
        </div>

        <span
          class="absolute top-5 left-5 inline-block px-3 py-1 text-[10px] font-medium uppercase tracking-[0.22em] text-white sm:top-6 sm:left-6"
          style={`background:${categoria.colorHex}`}
        >
          {categoria.nombre}
        </span>

        <div class="absolute right-0 bottom-0 left-0 p-5 sm:p-10">
          <h2
            class="max-w-3xl font-sans text-[24px] font-medium leading-[1.15] tracking-tight text-white sm:text-[34px] sm:leading-[1.1]"
          >
            {titulo}
          </h2>
          <p class="mt-3 max-w-2xl text-[13px] leading-snug text-white/85 sm:text-base">
            {copete}
          </p>
          <p class="mt-3 text-[11px] uppercase tracking-[0.18em] text-white/60 sm:mt-4">
            Por <span class="text-white/90">{autor.nombre}</span> · {
              formatRelative(fechaPublicacion, SAMPLE_TODAY)
            }
          </p>
        </div>
      </div>
    </a>
  </div>
</section>
