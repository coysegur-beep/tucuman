---
import type { ResolvedArticle } from "~/lib/types";
import ArticleCard from "./ArticleCard.astro";

interface Props {
  articles: ResolvedArticle[];
}

const { articles } = Astro.props;
const [hero, ...rest] = articles;
const medium = rest.slice(0, 4);
---

<section
  class="border-t-2 border-carmin bg-bone py-12"
  aria-labelledby="featured-grid-heading"
>
  <div class="mx-auto max-w-[1400px] px-6">
    <h2
      id="featured-grid-heading"
      class="mb-8 font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin"
    >
      Destacadas
    </h2>

    <div
      class="grid grid-cols-1 gap-y-8 md:grid-cols-4 md:grid-rows-2 md:gap-x-6 md:gap-y-8 md:h-[600px]"
    >
      {
        hero && (
          <ArticleCard
            article={hero}
            variant="hero"
            showAuthor
            class="md:col-span-2 md:row-span-2 md:h-full"
          />
        )
      }

      {
        medium.map((art) => (
          <ArticleCard
            article={art}
            variant="card"
            showAuthor
            imageClass="relative h-[130px] shrink-0 overflow-hidden"
            titleClass="mt-2 font-serif text-[16px] leading-[1.2] text-ink transition group-hover:text-carmin"
            class="md:h-full"
          />
        ))
      }
    </div>
  </div>
</section>
