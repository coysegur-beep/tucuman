---
import type { ResolvedArticle } from "~/lib/types";

interface Props {
  articles: ResolvedArticle[];
}

const { articles } = Astro.props;
const [hero, ...rest] = articles;
const medium = rest.slice(0, 4);
---

<section
  class="border-t-2 border-carmin bg-bone py-12"
  aria-labelledby="featured-grid-heading"
>
  <div class="mx-auto max-w-[1400px] px-6">
    <h2
      id="featured-grid-heading"
      class="mb-8 font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin"
    >
      Destacadas
    </h2>

    <div
      class="grid grid-cols-1 gap-y-8 md:grid-cols-4 md:grid-rows-2 md:gap-x-6 md:gap-y-8 md:h-[600px]"
    >
      {
        hero && (
          <article class="md:col-span-2 md:row-span-2 md:h-full">
            <a
              href={hero.url}
              class="group flex h-full cursor-pointer flex-col"
            >
              <div class="relative h-[240px] overflow-hidden md:h-auto md:flex-1 md:min-h-0">
                <img
                  src={hero.imagenPrincipal.url}
                  alt={hero.imagenPrincipal.alt}
                  width="1600"
                  height="900"
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover transition duration-300 group-hover:opacity-85"
                />
              </div>
              <div class="shrink-0 pt-4">
                <span
                  class="inline-block px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.22em] text-white"
                  style={`background:${hero.categoria.colorHex}`}
                >
                  {hero.categoria.nombre}
                </span>
                <h3 class="mt-3 font-serif text-[26px] leading-[1.15] text-ink transition group-hover:text-carmin sm:text-[30px]">
                  {hero.titulo}
                </h3>
                <p class="mt-3 text-[10px] font-medium uppercase tracking-[0.22em] text-carbon/55">
                  Por {hero.autor.nombre}
                </p>
              </div>
            </a>
          </article>
        )
      }

      {
        medium.map((art) => (
          <article class="md:h-full">
            <a
              href={art.url}
              class="group flex h-full cursor-pointer flex-col"
            >
              <div class="relative h-[130px] shrink-0 overflow-hidden">
                <img
                  src={art.imagenPrincipal.url}
                  alt={art.imagenPrincipal.alt}
                  width="800"
                  height="500"
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-300 group-hover:opacity-85"
                />
              </div>
              <div class="pt-3">
                <span
                  class="inline-block px-2 py-0.5 text-[9px] font-medium uppercase tracking-[0.22em] text-white"
                  style={`background:${art.categoria.colorHex}`}
                >
                  {art.categoria.nombre}
                </span>
                <h3 class="mt-2 font-serif text-[16px] leading-[1.2] text-ink transition group-hover:text-carmin">
                  {art.titulo}
                </h3>
                <p class="mt-2 text-[9px] font-medium uppercase tracking-[0.2em] text-carbon/55">
                  {art.autor.nombre}
                </p>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
