---
import type { ResolvedArticle } from "~/lib/types";

interface Props {
  columns: ResolvedArticle[];
}

const { columns } = Astro.props;
---

<section class="border-t border-black/5 bg-white py-14" aria-labelledby="opinion-heading">
  <div class="mx-auto max-w-[1400px] px-6">
    <div class="mb-8 flex items-baseline justify-between gap-4">
      <h2
        id="opinion-heading"
        class="font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin"
      >
        Opinión
      </h2>
      <a
        href="/opinion"
        class="text-[11px] uppercase tracking-[0.18em] text-carbon/60 transition hover:text-ink"
      >
        Todos los columnistas →
      </a>
    </div>

    <div class="grid gap-10 sm:gap-8 md:grid-cols-3">
      {
        columns.map((col) => (
          <article class="border-l-2 border-carmin pl-5">
            <a href={col.url} class="group block">
              <div class="flex items-center gap-3">
                <img
                  src={col.autor.foto}
                  alt={`Foto de ${col.autor.nombre}`}
                  width="48"
                  height="48"
                  loading="lazy"
                  class="h-12 w-12 flex-shrink-0 rounded-full object-cover"
                />
                <div class="min-w-0">
                  <p class="text-sm font-medium text-ink">{col.autor.nombre}</p>
                  <p class="truncate text-[11px] uppercase tracking-[0.16em] text-carbon/55">
                    {col.autor.cargo}
                  </p>
                </div>
              </div>

              <h3 class="mt-5 font-serif text-[22px] leading-[1.2] italic text-ink transition group-hover:text-carmin">
                “{col.titulo}”
              </h3>

              <p class="mt-3 text-sm leading-relaxed text-carbon/80">
                {col.copete}
              </p>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
