---
import type { ResolvedArticle } from "~/lib/types";
import ArticleCard from "./ArticleCard.astro";

interface Props {
  articles: ResolvedArticle[];
}

const { articles } = Astro.props;
---

<section class="bg-bone py-12" aria-labelledby="lo-que-importa-hoy">
  <div class="mx-auto max-w-[1400px] px-6">
    <h2
      id="lo-que-importa-hoy"
      class="mb-7 font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin"
    >
      Lo que importa hoy
    </h2>

    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        articles.map((art) => (
          <ArticleCard
            article={art}
            variant="card"
            showAuthor
            showTime
            imageClass="relative h-[130px] w-full shrink-0 overflow-hidden"
            titleClass="mt-3 font-serif text-[20px] leading-[1.2] text-ink transition group-hover:text-carmin"
          />
        ))
      }
    </div>
  </div>
</section>
