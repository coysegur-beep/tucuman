---
import type { ResolvedArticle } from "~/lib/types";
import { formatRelative } from "~/lib/format";
import { SAMPLE_TODAY } from "~/lib/now";

interface Props {
  articles: ResolvedArticle[];
}

const { articles } = Astro.props;
---

<section class="bg-bone py-12" aria-labelledby="lo-que-importa-hoy">
  <div class="mx-auto max-w-[1400px] px-6">
    <h2
      id="lo-que-importa-hoy"
      class="mb-7 font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin"
    >
      Lo que importa hoy
    </h2>

    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        articles.map((art) => (
          <article>
            <a href={art.url} class="group block">
              <div class="relative h-[130px] w-full overflow-hidden">
                <img
                  src={art.imagenPrincipal.url}
                  alt={art.imagenPrincipal.alt}
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  loading="lazy"
                  width="800"
                  height="500"
                />
              </div>

              <div class="mt-4">
                <span
                  class="inline-block px-2 py-1 text-[9px] font-medium uppercase tracking-[0.22em] text-white"
                  style={`background:${art.categoria.colorHex}`}
                >
                  {art.categoria.nombre}
                </span>

                <h3 class="mt-3 font-serif text-[20px] leading-[1.2] text-ink transition group-hover:text-carmin">
                  {art.titulo}
                </h3>

                <p class="mt-3 text-[11px] uppercase tracking-[0.16em] text-carbon/55">
                  {art.autor.nombre} ·{" "}
                  {formatRelative(art.fechaPublicacion, SAMPLE_TODAY)}
                </p>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
