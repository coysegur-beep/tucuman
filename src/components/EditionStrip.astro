---
import type { ResolvedArticle } from "~/lib/types";

interface Props {
  cover: ResolvedArticle;
}

const { cover } = Astro.props;
---

<aside class="bg-carmin text-white">
  <div class="mx-auto flex max-w-[1400px] items-center gap-5 px-6 py-3">
    <span
      class="flex-shrink-0 border-r border-white/30 pr-5 text-[10px] font-medium uppercase tracking-[0.22em] text-white/90"
    >
      Edición de hoy
    </span>
    <a
      href={cover.url}
      class="line-clamp-1 text-sm font-medium text-white transition hover:text-white/80 sm:text-[15px]"
    >
      {cover.titulo}
    </a>
  </div>
</aside>
