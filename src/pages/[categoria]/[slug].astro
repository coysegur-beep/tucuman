---
import type { GetStaticPaths } from "astro";
import PageLayout from "~/layouts/PageLayout.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import CategoryBadge from "~/components/CategoryBadge.astro";
import { CATEGORIES } from "~/lib/categories";
import {
  getAllResolved,
  getArticleBySlug,
  getRelatedArticles,
} from "~/data/sample-articles";
import { formatLongDate, formatTime } from "~/lib/format";
import {
  buildArticleSchema,
  ogImageFromArticle,
  type ArticleMeta,
} from "~/lib/seo";

export const getStaticPaths = (() => {
  return getAllResolved().map((art) => ({
    params: { categoria: art.categoria.slug, slug: art.slug },
  }));
}) satisfies GetStaticPaths;

const { categoria: categoriaSlug, slug } = Astro.params;
const article = getArticleBySlug(slug as string);

if (!article || article.categoria.slug !== categoriaSlug) {
  return Astro.redirect("/404");
}

const related = getRelatedArticles(article, 3);
const fechaPub = formatLongDate(article.fechaPublicacion);
const horaPub = formatTime(article.fechaPublicacion);
const fechaUpd = article.fechaActualizacion
  ? formatTime(article.fechaActualizacion)
  : null;

const isOpinion = article.tags.includes("opinion");

const articleSchema = buildArticleSchema(article);
const ogImage = ogImageFromArticle(article.imagenPrincipal.url);
const articleMeta: ArticleMeta = {
  publishedTime: article.fechaPublicacion,
  modifiedTime: article.fechaActualizacion ?? article.fechaPublicacion,
  author: article.autor.nombre,
  section: article.categoria.nombre,
  tags: article.tags,
};
const twitterCreator = article.autor.redes?.twitter
  ? `@${article.autor.redes.twitter}`
  : undefined;
---

<PageLayout
  title={article.titulo}
  description={article.copete}
  image={ogImage}
  ogType="article"
  articleMeta={articleMeta}
  twitterCreator={twitterCreator}
  schema={articleSchema}
>
  <article class="bg-white">
    <header class="mx-auto max-w-3xl px-6 pt-12 pb-6 sm:pt-16">
      {
        article.kicker && (
          <p
            class="text-[11px] font-medium uppercase tracking-[0.22em]"
            style={`color:${article.categoria.colorHex}`}
          >
            {article.kicker}
          </p>
        )
      }

      <h1
        class:list={[
          "mt-3 font-serif text-[34px] font-medium leading-[1.1] text-carbon sm:text-[44px]",
          isOpinion && "italic",
        ]}
      >
        {article.titulo}
      </h1>

      <p class="mt-4 text-[16px] leading-[1.5] font-normal text-carbon/65 sm:text-[18px]">
        {article.copete}
      </p>

      <div class="mt-8 flex items-center gap-4 border-t border-b border-black/10 py-5">
        <a
          href={`/autor/${article.autor.slug}`}
          class="flex-shrink-0"
          aria-label={`Ver perfil de ${article.autor.nombre}`}
        >
          <img
            src={article.autor.foto}
            alt={`Foto de ${article.autor.nombre}`}
            width="48"
            height="48"
            loading="eager"
            class="h-12 w-12 rounded-full object-cover"
          />
        </a>
        <div class="min-w-0 flex-1">
          <a
            href={`/autor/${article.autor.slug}`}
            class="text-[15px] font-medium text-ink transition hover:text-carmin"
          >
            {article.autor.nombre}
          </a>
          <p class="mt-1 text-[10px] uppercase tracking-[0.18em] text-carbon/55">
            {article.autor.cargo} · {fechaPub} · {horaPub} hs · {article.tiempoLectura} min
            {fechaUpd && ` · Actualizado ${fechaUpd}`}
          </p>
        </div>
        <div class="hidden items-center gap-2 sm:flex">
          <CategoryBadge category={article.categoria} size="xs" asLink />
        </div>
      </div>
    </header>

    <figure class="mx-auto mt-8 max-w-[1280px] px-0 sm:px-6">
      <div class="aspect-[16/9] w-full overflow-hidden bg-bone">
        <img
          src={article.imagenPrincipal.url}
          alt={article.imagenPrincipal.alt}
          width="1600"
          height="900"
          loading="eager"
          fetchpriority="high"
          class="h-full w-full object-cover"
        />
      </div>
      {
        article.imagenPrincipal.caption && (
          <figcaption class="mx-auto mt-3 max-w-3xl px-6 text-[12px] italic leading-relaxed text-carbon/60">
            {article.imagenPrincipal.caption}
          </figcaption>
        )
      }
    </figure>

    <div
      class:list={[
        "article-body mx-auto mt-10 max-w-3xl px-6",
        !isOpinion && "article-body--news",
        isOpinion && "article-body--opinion",
      ]}
      set:html={article.contenidoHtml ?? ""}
    />

    {
      article.tags.length > 0 && (
        <div class="mx-auto mt-12 flex max-w-3xl flex-wrap gap-2 px-6">
          {article.tags.map((tag) => (
            <span class="rounded-sm bg-bone px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-carbon/65">
              #{tag}
            </span>
          ))}
        </div>
      )
    }

    <div class="mx-auto mt-12 max-w-3xl border-t border-black/10 px-6 pt-8">
      <p class="text-[10px] uppercase tracking-[0.22em] text-carbon/50">
        Compartir esta nota
      </p>
      <div class="mt-3 flex gap-2">
        {
          (
            [
              { label: "Compartir en X", icon: "x" },
              { label: "Compartir en Facebook", icon: "fb" },
              { label: "Compartir en WhatsApp", icon: "wa" },
              { label: "Copiar enlace", icon: "link" },
            ] as const
          ).map((s) => (
            <button
              type="button"
              aria-label={s.label}
              class="flex h-9 w-9 items-center justify-center rounded-full border border-black/15 text-carbon/65 transition hover:border-carmin hover:text-carmin"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                {s.icon === "x" && (
                  <path d="M18.244 2H21.5l-7.55 8.63L23 22h-6.84l-5.36-6.85L4.62 22H1.36l8.07-9.22L1 2h7l4.85 6.2L18.244 2zm-2.4 18h1.86L7.32 4H5.36l10.484 16z" />
                )}
                {s.icon === "fb" && (
                  <path d="M22 12a10 10 0 1 0-11.56 9.88V14.9H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.9h-2.33v6.98A10 10 0 0 0 22 12z" />
                )}
                {s.icon === "wa" && (
                  <path d="M17.5 14.4c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.27-.47-2.42-1.5-.9-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.5s1.07 2.9 1.22 3.1c.15.2 2.1 3.2 5.07 4.5.71.3 1.27.48 1.7.62.71.23 1.36.2 1.87.12.57-.08 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35zM12.05 22h-.04A9.95 9.95 0 0 1 6.96 20.6L2 22l1.43-4.93a9.92 9.92 0 0 1-1.32-4.97C2.11 6.55 6.57 2.1 12.05 2.1c2.66 0 5.16 1.04 7.04 2.92a9.85 9.85 0 0 1 2.92 7.05c0 5.48-4.46 9.93-9.96 9.93z" />
                )}
                {s.icon === "link" && (
                  <path d="M3.9 12a3.1 3.1 0 0 1 3.1-3.1h4v-2H7a5.1 5.1 0 0 0 0 10.2h4v-2H7A3.1 3.1 0 0 1 3.9 12zM8 13h8v-2H8v2zm9-6h-4v2h4a3.1 3.1 0 0 1 0 6.2h-4v2h4A5.1 5.1 0 0 0 17 7z" />
                )}
              </svg>
            </button>
          ))
        }
      </div>
      <p class="mt-3 text-[11px] text-carbon/45">
        Botones decorativos por ahora — el handler real va en Fase 4 (SEO + share).
      </p>
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="mt-20 border-t border-black/10 bg-bone py-14" aria-labelledby="related-heading">
        <div class="mx-auto max-w-[1400px] px-6">
          <h2
            id="related-heading"
            class="mb-8 font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin"
          >
            Notas relacionadas
          </h2>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((art) => (
              <ArticleCard
                article={art}
                variant="card"
                showCopete
                showAuthor
                showTime
                imageClass="relative h-[180px] w-full shrink-0 overflow-hidden"
              />
            ))}
          </div>
        </div>
      </section>
    )
  }
</PageLayout>
