---
import type { GetStaticPaths } from "astro";
import PageLayout from "~/layouts/PageLayout.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import { CATEGORIES, getCategory } from "~/lib/categories";
import { getArticlesByCategory } from "~/lib/articles";

export const getStaticPaths = (() => {
  return CATEGORIES.map((c) => ({
    params: { categoria: c.slug },
  }));
}) satisfies GetStaticPaths;

const { categoria: categoriaSlug } = Astro.params;
const categoria = getCategory(categoriaSlug as Parameters<typeof getCategory>[0]);
const articles = await getArticlesByCategory(categoria.slug);
const [lead, ...rest] = articles;

const description = `${categoria.descripcion} — todas las notas de la sección ${categoria.nombre} en El Tucumán.`;
---

<PageLayout
  title={categoria.nombre}
  description={description}
>
  <main class="bg-white">
    <header class="border-t-2 bg-bone py-12" style={`border-color:${categoria.colorHex}`}>
      <div class="mx-auto max-w-[1400px] px-6">
        <p
          class="text-[11px] font-medium uppercase tracking-[0.22em]"
          style={`color:${categoria.colorHex}`}
        >
          Sección
        </p>
        <h1 class="mt-3 font-serif text-[44px] leading-[1.05] text-ink sm:text-[56px]">
          {categoria.nombre}
        </h1>
        <p class="mt-4 max-w-2xl text-base text-carbon/80">
          {categoria.descripcion}
        </p>
      </div>
    </header>

    {
      articles.length === 0 ? (
        <div class="mx-auto max-w-[1400px] px-6 py-20 text-center text-carbon/70">
          <p class="font-serif text-2xl text-ink">Todavía no hay notas en esta sección.</p>
          <p class="mt-3 text-sm">Volvé pronto — la redacción está sumando coberturas todos los días.</p>
        </div>
      ) : (
        <div class="mx-auto max-w-[1400px] px-6 py-14">
          <ArticleCard
            article={lead}
            variant="card"
            showCopete
            showAuthor
            showTime
            imageClass="relative h-[280px] w-full shrink-0 overflow-hidden sm:h-[380px]"
            titleClass="mt-4 font-serif text-[28px] leading-[1.1] text-ink transition group-hover:text-carmin sm:text-[34px]"
            badgeSize="sm"
            class="border-b border-black/10 pb-12"
          />

          {rest.length > 0 && (
            <div class="grid gap-x-8 gap-y-12 pt-12 sm:grid-cols-2 lg:grid-cols-3">
              {rest.map((art) => (
                <ArticleCard
                  article={art}
                  variant="card"
                  showCopete
                  showAuthor
                  showTime
                  imageClass="relative h-[180px] w-full shrink-0 overflow-hidden"
                />
              ))}
            </div>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
