---
import type { GetStaticPaths } from "astro";
import PageLayout from "~/layouts/PageLayout.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import { SAMPLE_AUTHORS, getSampleAuthor } from "~/data/sample-authors";
import { getArticlesByAuthor } from "~/data/sample-articles";
import { absoluteUrl, buildPersonSchema } from "~/lib/seo";

export const getStaticPaths = (() => {
  return SAMPLE_AUTHORS.map((a) => ({ params: { slug: a.slug } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const author = getSampleAuthor(slug as string);
const articles = getArticlesByAuthor(author.slug);

const schema = buildPersonSchema(author);
const ogImage = absoluteUrl(author.foto);
const description = `${author.cargo} en El Tucumán. ${author.bio}`;
const twitterCreator = author.redes?.twitter
  ? `@${author.redes.twitter}`
  : undefined;

const SOCIAL_LINKS = [
  author.redes?.twitter && {
    label: `${author.nombre} en X / Twitter`,
    href: `https://x.com/${author.redes.twitter}`,
    icon: "x",
  },
  author.redes?.instagram && {
    label: `${author.nombre} en Instagram`,
    href: `https://instagram.com/${author.redes.instagram}`,
    icon: "instagram",
  },
  author.redes?.linkedin && {
    label: `${author.nombre} en LinkedIn`,
    href: `https://www.linkedin.com/in/${author.redes.linkedin}`,
    icon: "linkedin",
  },
].filter((s): s is { label: string; href: string; icon: string } => Boolean(s));
---

<PageLayout
  title={author.nombre}
  description={description}
  image={ogImage}
  twitterCreator={twitterCreator}
  schema={schema}
>
  <main class="bg-white">
    <header class="bg-bone py-12 sm:py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <img
          src={author.foto}
          alt={`Foto de ${author.nombre}`}
          width="160"
          height="160"
          loading="eager"
          class="mx-auto h-32 w-32 rounded-full object-cover ring-1 ring-black/5 sm:h-40 sm:w-40"
        />

        <h1 class="mt-6 font-serif text-[28px] font-medium leading-[1.1] text-carbon sm:text-[36px]">
          {author.nombre}
        </h1>

        <p class="mt-2 text-[11px] font-medium uppercase tracking-[0.22em] text-carmin">
          {author.cargo}
        </p>

        <p class="mx-auto mt-5 max-w-2xl text-[15px] leading-relaxed text-carbon/75">
          {author.bio}
        </p>

        {
          SOCIAL_LINKS.length > 0 && (
            <ul class="mt-6 flex justify-center gap-3">
              {SOCIAL_LINKS.map((s) => (
                <li>
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.label}
                    class="flex h-9 w-9 items-center justify-center rounded-full border border-black/15 text-carbon/65 transition hover:border-carmin hover:text-carmin"
                  >
                    {s.icon === "x" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M18.244 2H21.5l-7.55 8.63L23 22h-6.84l-5.36-6.85L4.62 22H1.36l8.07-9.22L1 2h7l4.85 6.2L18.244 2zm-2.4 18h1.86L7.32 4H5.36l10.484 16z" />
                      </svg>
                    )}
                    {s.icon === "instagram" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="2" y="2" width="20" height="20" rx="5" />
                        <circle cx="12" cy="12" r="4" />
                        <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
                      </svg>
                    )}
                    {s.icon === "linkedin" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M19 0h-14a5 5 0 0 0-5 5v14a5 5 0 0 0 5 5h14a5 5 0 0 0 5-5v-14a5 5 0 0 0-5-5zM8 19h-3v-9h3v9zm-1.5-10.3a1.7 1.7 0 1 1 0-3.4 1.7 1.7 0 0 1 0 3.4zm12.5 10.3h-3v-4.5c0-1.1-.4-1.8-1.4-1.8-.8 0-1.2.5-1.4 1-.1.2-.1.5-.1.8v4.5h-3v-9h3v1.3c.4-.6 1.1-1.4 2.6-1.4 1.9 0 3.3 1.2 3.3 3.9v5.2z" />
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    <div class="mx-auto max-w-[1400px] border-t border-black/10 px-6 py-14">
      {
        articles.length === 0 ? (
          <div class="py-16 text-center">
            <p class="font-serif text-2xl text-ink">
              Próximamente publicaciones de este autor.
            </p>
            <p class="mt-3 text-sm text-carbon/65">
              {author.nombre.split(" ")[0]} está por sumar su primera firma a El Tucumán.
            </p>
          </div>
        ) : (
          <>
            <h2 class="mb-8 font-sans text-[11px] font-medium uppercase tracking-[0.22em] text-carmin">
              {articles.length} {articles.length === 1 ? "publicación" : "publicaciones"} firmadas
            </h2>
            <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
              {articles.map((art) => (
                <ArticleCard
                  article={art}
                  variant="card"
                  showCopete
                  showAuthor={false}
                  showTime
                  imageClass="relative h-[180px] w-full shrink-0 overflow-hidden"
                />
              ))}
            </div>
          </>
        )
      }
    </div>
  </main>
</PageLayout>
