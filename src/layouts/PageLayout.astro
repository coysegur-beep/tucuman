---
import BaseLayout from "./BaseLayout.astro";
import HeaderBanner from "~/components/HeaderBanner.astro";
import NavBar from "~/components/NavBar.astro";
import MegaMenu from "~/components/MegaMenu.astro";
import Newsletter from "~/components/Newsletter.astro";
import Footer from "~/components/Footer.astro";
import { SAMPLE_TODAY } from "~/lib/now";
import type { ArticleMeta } from "~/lib/seo";

type SchemaJsonLd = Record<string, unknown>;

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: "website" | "article";
  articleMeta?: ArticleMeta;
  twitterCreator?: string;
  robots?: string;
  schema?: SchemaJsonLd | SchemaJsonLd[];
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <HeaderBanner date={SAMPLE_TODAY} />
  <NavBar />
  <MegaMenu />
  <slot />
  <Newsletter />
  <Footer />
</BaseLayout>
